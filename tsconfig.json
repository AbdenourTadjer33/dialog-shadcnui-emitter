{
    "compilerOptions": {
        "target": "ES2022",
        "lib": ["ES2022", "dom", "dom.iterable"],
        "module": "ESNext",
        "moduleResolution": "bundler",
        "jsx": "react-jsx",
        "strict": true,
        "noEmit": true,
        "isolatedModules": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "baseUrl": ".",
        "paths": { "@/*": ["registry/*"] }
    },
    "include": ["registry", "demo", "*.tsx", "*.ts"]
}
